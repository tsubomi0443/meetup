{
  "name": "frontend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "autoprefixer": "^10.4.27",
    "daisyui": "4",
    "postcss": "^8.5.8",
    "tailwindcss": "3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "alpinejs": "^3.15.10",
    "htmx-ext-sse": "^2.2.4",
    "htmx.org": "^2.0.8"
  },
  "scripts": {
    "dev": "bunx tailwindcss -i ./global.css -o ../static/css/output.css --watch",
    "build:css": "bunx tailwindcss -i ./global.css -o ../static/css/output.css",
    "copy:vendor": "cp ./node_modules/htmx.org/dist/htmx.min.js ../static/vendor/htmx.min.js && cp ./node_modules/alpinejs/dist/cdn.min.js ../static/vendor/alpine.min.js && cp ./node_modules/htmx-ext-sse/dist/sse.min.js ../static/vendor/sse.min.js",
    "build": "bunx tailwindcss -i ./global.css -o ../static/css/output.css && cp ./node_modules/htmx.org/dist/htmx.min.js ../static/vendor/htmx.min.js && cp ./node_modules/htmx-ext-sse/dist/sse.min.js ../static/vendor/sse.min.js && cp ./node_modules/alpinejs/dist/cdn.min.js ../static/vendor/alpine.min.js"
  }
}
