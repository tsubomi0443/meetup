{
  "name": "frontend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "autoprefixer": "^10.5.0",
    "daisyui": "4.12.24",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.17"
  },
  "peerDependencies": {
    "typescript": "5"
  },
  "dependencies": {
    "alpinejs": "3.15.10",
    "es-toolkit": "1.45.1",
    "htmx-ext-sse": "2.2.4",
    "htmx.org": "2.0.8",
    "lucide": "^1.8.0"
  },
  "scripts": {
    "dev": "bunx tailwindcss -i ./global.css -o ../static/css/output.css --watch",
    "build:css": "bunx tailwindcss -i ./global.css -o ../static/css/output.css",
    "copy:htmx_alpinejs": "cp ./node_modules/htmx.org/dist/htmx.min.js ../static/vendor/htmx.min.js && cp ./node_modules/alpinejs/dist/cdn.min.js ../static/vendor/alpine.min.js && cp ./node_modules/htmx-ext-sse/dist/sse.min.js ../static/vendor/sse.min.js",
    "copy:lucide": "cp ./node_modules/lucide/dist/umd/lucide.min.js ../static/vendor/lucide.min.js && cp ./node_modules/lucide/dist/umd/lucide.min.js.map ../static/vendor/lucide.min.js.map",
    "copy:estoolkit": "cp ./node_modules/es-toolkit/dist/browser.global.js ../static/vendor/es-toolkit-global.js",
    "copy:vendor": "bun run copy:htmx_alpinejs && bun run copy:lucide && bun run copy:estoolkit",
    "build": "bun run build:css && bun run copy:vendor"
  }
}
